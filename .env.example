# ── Kimi / Moonshot — генерация ответов (OpenAI-совместимый API) ──────
MOONSHOT_API_KEY=sk-...
# Международный эндпоинт: https://api.moonshot.ai/v1
# Китайский эндпоинт:     https://api.moonshot.cn/v1
KIMI_BASE_URL=https://api.moonshot.ai/v1
# Имя модели смотри в консоли Moonshot (kimi-k2.6, kimi-k2.5, moonshot-v1-8k/32k/128k)
KIMI_MODEL=kimi-k2.6
# Лимит выходных токенов. kimi-k2.6 «думает» — reasoning тоже тратит токены,
# поэтому с запасом, иначе ответ обрезается/пустой.
KIMI_MAX_TOKENS=4096

# ── OpenAI — эмбеддинги (text-embedding-3-small, 1536 измерений) ──────
OPENAI_API_KEY=sk-...
EMBED_MODEL=text-embedding-3-small

# ── Supabase ─────────────────────────────────────────────────────────
SUPABASE_URL=https://xxxxxxxx.supabase.co
# service_role key: Supabase Dashboard → Project Settings → API → service_role
SUPABASE_SERVICE_KEY=eyJhbGci...

# ── Поведение бота ───────────────────────────────────────────────────
# false — только логировать (НИЧЕГО не отправлять). true — отвечать автоматически.
AUTO_REPLY=false
# Имя ИИ-ассистента — как он представляется клиентам
AGENT_NAME=Alex
# Чей стиль перенимаем (владелец компании)
OWNER_NAME=Антон
# Имя владельца в экспортах WhatsApp (для parse_and_upload: кто = Антон)
CHAT_OWNER_NAME=Prime Fusion Inc
# Номер для уведомлений о переданных вопросах (цифры с кодом страны). Пусто = не слать.
ESCALATION_NUMBER=
# Сколько мс ждать после последнего сообщения клиента перед ответом
# (чтобы не отвечать на каждое сообщение из серии отдельно)
DEBOUNCE_MS=8000
# Стиль: сколько похожих прошлых ответов Антона подмешивать
RAG_TOP_K=6
RAG_MIN_SIMILARITY=0.3
# Факты (база знаний из брошюры/договора/рассылки): сколько кусков подмешивать
KNOW_TOP_K=6
KNOW_MIN_SIMILARITY=0.25

# ── Веб-панель исключений (node web.js) ──────────────────────────────
WEB_PORT=3000

# ── Опционально ──────────────────────────────────────────────────────
# Путь к Chrome/Chromium, если puppeteer не находит браузер сам.
# Windows пример: C:\Program Files\Google\Chrome\Application\chrome.exe
# CHROME_PATH=
#
# Версия WhatsApp Web (фикс "Execution context was destroyed").
# Свежие файлы: https://github.com/wppconnect-team/wa-version/tree/main/html
# WA_WEB_VERSION_URL=https://raw.githubusercontent.com/wppconnect-team/wa-version/main/html/2.3000.1038673194-alpha.html
